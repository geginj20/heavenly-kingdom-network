# App Configuration
VITE_APP_NAME=Heavenly Kingdom Network
VITE_APP_URL=https://heavenlykingdom.network

# Feature Flags
VITE_ENABLE_LIVE_STREAMING=true
VITE_ENABLE_DONATIONS=true

# API Backend (empty = same origin, for local proxy or Cloudflare deployment)
VITE_API_BASE_URL=

# Google OAuth (optional - get from Google Cloud Console > APIs & Services > Credentials)
VITE_GOOGLE_CLIENT_ID=

# Paystack (for African payments - M-Pesa, cards, etc.)
# Get keys from https://dashboard.paystack.com/#/settings/developer
VITE_PAYSTACK_PUBLIC_KEY=
# Backend env: PAYSTACK_SECRET_KEY=

# Wise API (for international exchange rates & payouts)
# Get token from https://wise.com/user/settings/api
# Backend env: WISE_API_TOKEN=
