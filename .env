# App Configuration
VITE_APP_NAME=Heavenly Kingdom Network
VITE_APP_URL=https://heavenlykingdom.network

# Feature Flags
VITE_ENABLE_LIVE_STREAMING=true
VITE_ENABLE_DONATIONS=true

# API Backend (empty = same origin, for local proxy or Cloudflare deployment)
VITE_API_BASE_URL=

# Admin (default: admin / admin123)
VITE_ADMIN_USERNAME=admin
VITE_ADMIN_PASSWORD=admin123
