{
  "name": "hkn-api",
  "private": true,
  "type": "module",
  "version": "1.0.0",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "build": "tsc",
    "seed": "tsx --env-file=.env src/lib/seed.ts",
    "migrate": "drizzle-kit push",
    "migrate:generate": "drizzle-kit generate",
    "deploy": "wrangler deploy"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.8.0",
    "@supabase/supabase-js": "^2.108.2",
    "drizzle-orm": "^0.40.0",
    "hono": "^4.12.25",
    "pg": "^8.21.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.30.0",
    "tsx": "^4.19.0",
    "typescript": "~5.9.3",
    "wrangler": "^4.0.0"
  }
}
